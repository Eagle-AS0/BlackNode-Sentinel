# ──────────────────────────────────────────────────────────────
# BlackNode Sentinel — Environment Variables Template
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and update values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=blacknode_user
MONGO_INITDB_ROOT_PASSWORD=Dev123!
MONGO_INITDB_DATABASE=blacknode-sentinel
MONGO_EXTERNAL_PORT=27017

# ── Backend ──────────────────────────────────────────────────
NODE_ENV=production
BACKEND_EXTERNAL_PORT=5004
JWT_SECRET=change_me_to_a_random_64_char_string
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_EXTERNAL_PORT=3000

# ── Optional: ML Engine ──────────────────────────────────────
# Uncomment and set if running the Python ML engine
# ML_ENGINE_URL=http://ml-engine:8000
# ENABLE_ML_DETECTION=true
